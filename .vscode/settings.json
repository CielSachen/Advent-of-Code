{
  /* Text Editor */
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "files.insertFinalNewline": true,

  /* Python Support */
  "python.analysis.autoImportCompletions": true,
  "python.analysis.fixAll": ["source.unusedImports", "source.convertImportFormat"],
  "python.analysis.typeCheckingMode": "strict",

  /* TOML Support */
  "evenBetterToml.schema.associations": { "ruff.toml": "http:/*json.schemastore.org/ruff" },

  /* Prettier Extension */
  "prettier.configPath": "./.prettierrc",

  /* Ruff Extension */
  "ruff.configuration": "${workspaceFolder}/ruff.toml",
  "ruff.configurationPreference": "filesystemFirst",

  /* Python Files Only Settings */
  "[python]": {
    /* Text Editor */
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4
  }
}
